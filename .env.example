# ─────────────────────────────────────────────────────────────────────────────
# Credenciales de Instagram (instagrapi — API privada)
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas .env a git (ya está en .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# Tu usuario de Instagram (sin @)
INSTAGRAM_USERNAME=tu_usuario

# Tu contraseña de Instagram
INSTAGRAM_PASSWORD=tu_contraseña

# Caption por defecto para cada reel (soporta hashtags y emojis)
REEL_CAPTION=✨ Motivación diaria 🚀 #motivacion #mindset #diario

# ─────────────────────────────────────────────────────────────────────────────
# Control de pipeline
# ─────────────────────────────────────────────────────────────────────────────

# Cambia a true cuando quieras activar el upload automático a Instagram
UPLOAD=false
