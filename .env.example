# ─────────────────────────────────────────────────────────────────────────────
# Instagram Graph API credentials
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Long-lived User Access Token (generated from Facebook Developer Console)
INSTAGRAM_ACCESS_TOKEN=YOUR_LONG_LIVED_ACCESS_TOKEN_HERE

# Numeric Instagram Business / Creator account ID
INSTAGRAM_USER_ID=YOUR_INSTAGRAM_BUSINESS_ACCOUNT_ID

# Publicly accessible HTTPS base URL where the rendered .mp4 will be hosted
# Example: https://your-bucket.s3.amazonaws.com  or  https://res.cloudinary.com/yourcloud
VIDEO_PUBLIC_BASE_URL=https://your-cdn.example.com

# Default caption appended to every post (supports hashtags & emojis)
REEL_CAPTION=✨ Daily motivation 🚀 #motivation #mindset #daily
